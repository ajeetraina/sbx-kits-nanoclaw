+    # ONECLI_URL reconciler. nanoclaw-start must launch the daemon BEFORE /setup
+    # runs (so the wizard's ping finds a live cli.sock), but on first setup that
+    # means the daemon comes up before OneCLI writes ONECLI_URL to .env. The
+    # daemon reads .env only at process start (readEnvFile does not refresh), so
+    # it stays pinned to the SDK cloud default (DEFAULT_URL=https://api.onecli.sh)
+    # and every ensureAgent 401s while spawning the agent container. The wizard's
+    # service step writes a fresh wrapper but never restarts the running process,
+    # so the stale URL sticks. This watcher restarts the daemon once the real URL
+    # lands, so it re-reads .env and targets the LOCAL vault. It reads whatever
+    # OneCLI actually wrote (no hard-coded host/port).
+    - command: |
+        cat > /usr/local/bin/nanoclaw-reconcile-onecli-url <<'RECONCILE'
+        #!/bin/sh
+        # Restart the NanoClaw daemon when ONECLI_URL first appears or changes in
+        # .env, so a process started before /setup re-reads the local vault URL
+        # instead of 401'ing against the OneCLI cloud default. See spec.yaml.
+        NC=/home/agent/nanoclaw
+        ENVF="$NC/.env"
+        SOCK="$NC/data/cli.sock"
+        url() { [ -f "$ENVF" ] && sed -n 's/^ONECLI_URL=//p' "$ENVF" | head -n1; }
+        restart() {
+          echo "reconcile-onecli-url: ONECLI_URL=$1 -> restarting daemon to re-read .env" >&2
+          pkill -f '/nanoclaw/dist/index.js' 2>/dev/null || true
+          sleep 1
+          mkdir -p "$NC/logs"
+          if [ -f "$NC/start-nanoclaw.sh" ]; then
+            ( cd "$NC" && nohup bash start-nanoclaw.sh >> logs/nanoclaw.log 2>&1 & ) || true
+          else
+            ( cd "$NC" && nohup node dist/index.js >> logs/nanoclaw.log 2>&1 & ) || true
+          fi
+          i=0
+          while [ $i -lt 20 ] && [ ! -S "$SOCK" ]; do sleep 1; i=$((i+1)); done
+          [ -S "$SOCK" ] \
+            && echo "reconcile-onecli-url: daemon back up (cli.sock after ${i}s)." >&2 \
+            || echo "reconcile-onecli-url: socket not up after ${i}s; see logs/nanoclaw.log." >&2
+        }
+        # Seed with the current value so an already-configured attach never
+        # triggers a spurious restart; only a CHANGE after start fires it.
+        last="$(url)"
+        end=$(( $(date +%s) + 900 ))
+        while [ "$(date +%s)" -lt "$end" ]; do
+          [ -f "$NC/.setup-done" ] && break
+          cur="$(url)"
+          if [ -n "$cur" ] && [ "$cur" != "$last" ]; then last="$cur"; restart "$cur"; fi
+          sleep 2
+        done
+        RECONCILE
+        chmod +x /usr/local/bin/nanoclaw-reconcile-onecli-url
+      user: "0"
+      description: Install ONECLI_URL reconciler (restarts the daemon when /setup writes the local vault URL, closing the stale-process 401 race)
